# ZAPHERA COFTAN Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
# Easypanel PostgreSQL internal link: postgres://ZAPHIRACOFTAN_database:5432/ZAPHIRACOFTAN?sslmode=disable
DATABASE_URL=postgres://ZAPHIRACOFTAN_database:5432/ZAPHIRACOFTAN?sslmode=disable

# Security & Dashboard API Access
# Generate a secure random token for your dashboard client (e.g. openssl rand -hex 32)
ADMIN_TOKEN=your_secure_dashboard_admin_token_here

# Google Sheets Webhook Integration
# The URL you get after deploying your Google Apps Script as a Web App
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/XXXXX/exec

# Snapchat Conversions API (CAPI)
SNAP_PIXEL_ID=your_snapchat_pixel_id
SNAP_ACCESS_TOKEN=your_snapchat_capi_token

# TikTok Conversions API (CAPI)
TIKTOK_PIXEL_ID=your_tiktok_pixel_id
TIKTOK_ACCESS_TOKEN=your_tiktok_capi_token
