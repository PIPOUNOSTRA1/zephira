# ZAPHERA COFTAN Frontend Environment Variables

# Backend API Endpoint
# Production: https://api.zaphiracoftan.shop
# Local Dev: http://localhost:5000
VITE_API_URL=http://localhost:5000

# Browser Pixel IDs (Used for frontend tracking)
VITE_TIKTOK_PIXEL_ID=your_tiktok_pixel_id_here
VITE_SNAP_PIXEL_ID=your_snapchat_pixel_id_here

# Admin Access Token (To access the admin.html confirmation dashboard)
# Must match the ADMIN_TOKEN set in the backend env variables
VITE_ADMIN_TOKEN=your_secure_dashboard_admin_token_here
